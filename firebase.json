{
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "database.rules.json",
      "storage.rules",
      ".github/**",
      ".git/**",
      ".gitignore",
      ".claude/**",
      "PLAN.md",
      "SPEC.md",
      "CONSTITUTION.md",
      "TASKS.md",
      "DEPLOY.md",
      "SETUP_FIREBASE_AUTH.md"
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
