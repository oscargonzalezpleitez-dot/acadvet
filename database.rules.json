{
  "rules": {

    "config": {
      ".read": true,
      ".write": false,
      "lab_location": {
        ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
      }
    },

    "login_lockout": {
      ".read": false,
      ".write": true
    },

    "materias": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$materiaId": {
        ".validate": "newData.hasChildren(['nombre', 'ciclo', 'estado'])"
      }
    },

    "alumnos": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$alumnoId": {
        "inscripciones": {
          "$materiaId": {
            "parciales": {
              "$parcialId": {
                ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100)"
              }
            },
            "asistencias": {
              "$asistId": {
                ".validate": "newData.hasChildren(['fecha', 'estado'])"
              }
            },
            "tareas": {
              "$tareaId": {
                ".validate": "newData.hasChildren(['nombre', 'subidoEn'])"
              }
            }
          }
        }
      }
    },

    "qr_sessions": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$sessionId": {
        "asistentes": {
          "$asistenteId": {
            ".validate": "newData.hasChildren(['nombre', 'carnet', 'ts'])"
          }
        }
      }
    },

    "solicitudes_registro": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null",
      "$solicitudId": {
        ".validate": "newData.hasChildren(['nombre', 'carnet', 'email', 'materias'])"
      }
    },

    "cuestionarios": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$quizId": {
        ".validate": "newData.hasChildren(['nombre', 'tiempo', 'activo'])"
      }
    },

    "cuestionarios_correctas": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
    },

    "cuestionarios_enviados": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$quizId": {
        "$carnetKey": {
          ".validate": "!data.exists() && newData.isNumber()"
        }
      }
    },

    "cuestionarios_resultados": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null",
      "$resultId": {
        ".validate": "newData.hasChildren(['cuestionarioId', 'alumno']) && !data.exists()"
      }
    },

    "lab_reports": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null",
      "$reportId": {
        ".validate": "newData.hasChildren(['student_name', 'student_id', 'tipo_preparacion', 'timestamp', 'foto_url'])"
      }
    },

    "lab_images": {
      ".read":  true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
    },

    "reminders": {
      ".read":  true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
    },

    "student_competencies": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$studentKey": {
        ".read":  "auth != null",
        "$compId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['student_id', 'student_name', 'comp_id', 'comp_name', 'status'])"
        }
      }
    }

  }
}
