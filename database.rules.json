{
  "rules": {

    "config": {
      ".read": false,
      ".write": false,
      "lab_location": {
        ".read": true,
        ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
      }
    },

    "login_lockout": {
      ".read": false,
      ".write": false
    },

    "materias": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$materiaId": {
        ".validate": "newData.hasChildren(['nombre', 'ciclo', 'estado'])"
      }
    },

    "alumnos": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$alumnoId": {
        "inscripciones": {
          "$materiaId": {
            "parciales": {
              "$parcialId": {
                ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100)"
              }
            },
            "asistencias": {
              "$asistId": {
                ".validate": "newData.hasChildren(['fecha', 'estado'])"
              }
            },
            "tareas": {
              "$tareaId": {
                ".validate": "newData.hasChildren(['nombre', 'subidoEn'])"
              }
            }
          }
        }
      }
    },

    "qr_sessions": {
      ".read":  "auth != null",
      "$sessionId": {
        ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
        "asistentes": {
          "$asistenteId": {
            ".write":    "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['nombre', 'carnet', 'ts'])"
          }
        }
      }
    },

    "grupos_sorteos": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$sorteoId": {
        ".validate": "newData.hasChildren(['materiaId', 'tamano', 'grupos', 'estado'])"
      }
    },

    "solicitudes_idx": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$carnetKey": {
        ".write": "auth != null && (auth.token.firebase.sign_in_provider === 'password' || !data.exists())",
        ".validate": "newData.isBoolean()"
      }
    },

    "solicitudes_registro": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null",
      "$solicitudId": {
        ".validate": "newData.hasChildren(['nombre', 'carnet', 'email', 'materias'])",
        "nombre":   { ".validate": "newData.isString() && newData.val().length <= 200" },
        "carnet":   { ".validate": "newData.isString() && newData.val().length <= 40" },
        "email":    { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 120)" },
        "telefono": { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 40)" },
        "fotoB64":  { ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 400000)" }
      }
    },

    "cuestionarios": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$quizId": {
        ".validate": "newData.hasChildren(['nombre', 'tiempo', 'activo'])"
      }
    },

    "cuestionarios_correctas": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
    },

    "cuestionarios_enviados": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$quizId": {
        "$carnetKey": {
          ".validate": "!data.exists() && newData.isNumber()"
        }
      }
    },

    "cuestionarios_resultados": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null",
      "$resultId": {
        ".validate": "newData.hasChildren(['cuestionarioId', 'alumno']) && !data.exists()"
      }
    },

    "lab_reports": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      ".write": "auth != null",
      "$reportId": {
        ".validate": "newData.hasChildren(['student_name', 'student_id', 'tipo_preparacion', 'timestamp', 'foto_url'])"
      }
    },

    "lab_images": {
      ".read":  true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
    },

    "reminders": {
      ".read":  true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider === 'password'"
    },

    "student_competencies": {
      ".read":  "auth != null && auth.token.firebase.sign_in_provider === 'password'",
      "$studentKey": {
        ".read":  "auth != null",
        "$compId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['student_id', 'student_name', 'comp_id', 'comp_name', 'status']) && (auth.token.firebase.sign_in_provider === 'password' || (newData.child('status').val() === 'pendiente' && !newData.child('validated_by').exists() && !newData.child('validated_at').exists()))"
        }
      }
    }

  }
}
